[debug] [2026-05-02T14:11:17.798Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/buzzly-4a038/rulesets {"name":"projects/buzzly-4a038/rulesets/d48a3603-7145-43d2-8c22-ff540d9f1132","source":{"files":[{"content":"rules_version = '2';\r\n\r\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function isAdmin() {\n      return request.auth != null\n        && request.auth.token.email == \"nutakkiabhiram@gmail.com\";\n    }\n\n    match /users/{userId} {\n      allow read: if request.auth != null && request.auth.uid == userId;\r\n\r\n      allow write: if request.auth != null\r\n        && request.auth.uid == userId\r\n        && request.resource.data.keys().hasOnly([\r\n          \"coins\",\r\n          \"displayName\",\r\n          \"email\",\r\n          \"createdAt\",\r\n          \"updatedAt\"\r\n        ])\r\n        && request.resource.data.coins is number\r\n        && request.resource.data.coins >= 0;\r\n\r\n      match /holdings/{marketId} {\r\n        allow read: if request.auth != null && request.auth.uid == userId;\r\n        allow delete: if request.auth != null && request.auth.uid == userId;\r\n\r\n        allow write: if request.auth != null\r\n          && request.auth.uid == userId\r\n          && request.resource.data.keys().hasOnly([\r\n            \"quantity\",\r\n            \"averagePrice\",\r\n            \"updatedAt\"\r\n          ])\r\n          && request.resource.data.quantity is number\r\n          && request.resource.data.quantity >= 0\r\n          && request.resource.data.averagePrice is number\r\n          && request.resource.data.averagePrice >= 0;\r\n      }\r\n    }\r\n\r\n    match /markets/{marketId} {\n      allow read: if request.auth != null;\n      allow delete: if isAdmin();\n      allow create: if request.auth != null\n        && validMarketData()\n        && (isAdmin()\n          || (request.resource.data.source == \"scheduled_drop\"\n            && marketId.matches(\"drop_.*\")));\n      allow update: if request.auth != null\n        && validMarketData();\n\n      function validMarketData() {\n        return request.resource.data.keys().hasOnly([\n            \"name\",\n            \"category\",\n            \"level\",\n            \"volatility\",\n            \"lastPrice\",\n            \"previousPrice\",\n            \"volume\",\n            \"supply\",\n            \"description\",\n            \"signal\",\n            \"color\",\n            \"totalSupply\",\n            \"dropPrice\",\n            \"soldDropSupply\",\n            \"unsoldDropSupply\",\n            \"activeTradableSupply\",\n            \"remainingDropSupply\",\n            \"status\",\n            \"source\",\n            \"createdBy\",\n            \"createdByName\",\n            \"createdAt\",\n            \"updatedAt\"\n          ])\n          && request.resource.data.name is string\n          && request.resource.data.category is string\n          && request.resource.data.level in [\"admin\", \"community\", \"private\"]\n          && request.resource.data.lastPrice is number\n          && request.resource.data.previousPrice is number\n          && request.resource.data.volume is number\n          && request.resource.data.totalSupply is number\n          && request.resource.data.totalSupply >= 1\n          && request.resource.data.dropPrice is number\n          && request.resource.data.dropPrice >= 1\n          && (!request.resource.data.keys().hasAny([\"soldDropSupply\"])\n            || (request.resource.data.soldDropSupply is number\n              && request.resource.data.soldDropSupply >= 0))\n          && (!request.resource.data.keys().hasAny([\"unsoldDropSupply\"])\n            || (request.resource.data.unsoldDropSupply is number\n              && request.resource.data.unsoldDropSupply >= 0))\n          && (!request.resource.data.keys().hasAny([\"activeTradableSupply\"])\n            || (request.resource.data.activeTradableSupply is number\n              && request.resource.data.activeTradableSupply >= 0))\n          && request.resource.data.remainingDropSupply is number\n          && request.resource.data.remainingDropSupply >= 0\n          && request.resource.data.status in [\"drop\", \"trading\"]\n          && (!request.resource.data.keys().hasAny([\"source\"])\n            || request.resource.data.source in [\"manual\", \"scheduled_drop\"])\n          && (!request.resource.data.keys().hasAny([\"createdBy\"])\n            || request.resource.data.createdBy is string);\n      }\n    }\n\r\n    match /balances/{userId} {\r\n      allow read: if request.auth != null;\r\n      allow write: if request.auth != null\r\n        && request.resource.data.keys().hasOnly([\r\n          \"coins\",\r\n          \"displayName\",\r\n          \"email\",\r\n          \"updatedAt\"\r\n        ])\r\n        && request.resource.data.coins is number\r\n        && request.resource.data.coins >= 0;\r\n    }\r\n\r\n    match /holdings/{holdingId} {\r\n      allow read: if request.auth != null;\r\n      allow delete: if request.auth != null;\r\n      allow write: if request.auth != null\r\n        && request.resource.data.keys().hasOnly([\r\n          \"userId\",\r\n          \"marketId\",\r\n          \"quantity\",\r\n          \"averagePrice\",\r\n          \"updatedAt\"\r\n        ])\r\n        && request.resource.data.userId is string\r\n        && request.resource.data.marketId is string\r\n        && request.resource.data.quantity is number\r\n        && request.resource.data.quantity >= 0\r\n        && request.resource.data.averagePrice is number\r\n        && request.resource.data.averagePrice >= 0;\r\n    }\r\n\r\n    match /orders/{orderId} {\r\n      allow read: if request.auth != null;\r\n      allow delete: if request.auth != null;\r\n      allow create, update: if request.auth != null\r\n        && request.resource.data.keys().hasOnly([\r\n          \"assetId\",\r\n          \"userId\",\r\n          \"user\",\r\n          \"ownerCoins\",\r\n          \"side\",\r\n          \"limitPrice\",\r\n          \"quantity\",\r\n          \"remaining\",\r\n          \"status\",\r\n          \"createdAt\",\r\n          \"updatedAt\"\r\n        ])\r\n        && request.resource.data.assetId is string\r\n        && request.resource.data.userId is string\r\n        && request.resource.data.user is string\r\n        && (!request.resource.data.keys().hasAny([\"ownerCoins\"])\r\n          || (request.resource.data.ownerCoins is number\r\n            && request.resource.data.ownerCoins >= 0))\r\n        && request.resource.data.side in [\"buy\", \"sell\"]\r\n        && request.resource.data.limitPrice is number\r\n        && request.resource.data.limitPrice >= 1\r\n        && request.resource.data.quantity is number\r\n        && request.resource.data.quantity >= 1\r\n        && request.resource.data.remaining is number\r\n        && request.resource.data.remaining >= 0\r\n        && request.resource.data.status in [\"open\", \"filled\", \"partially_filled\"];\r\n    }\r\n\r\n    match /trades/{tradeId} {\n      allow read: if request.auth != null;\n      allow delete: if request.auth != null;\n      allow create: if request.auth != null\n        && request.resource.data.keys().hasOnly([\r\n          \"assetId\",\r\n          \"buyerId\",\r\n          \"buyer\",\r\n          \"sellerId\",\r\n          \"seller\",\r\n          \"price\",\r\n          \"quantity\",\r\n          \"createdAt\"\r\n        ])\r\n        && request.resource.data.assetId is string\r\n        && request.resource.data.buyerId is string\r\n        && request.resource.data.buyer is string\r\n        && request.resource.data.sellerId is string\r\n        && request.resource.data.seller is string\r\n        && request.resource.data.price is number\r\n        && request.resource.data.price >= 1\r\n        && request.resource.data.quantity is number\n        && request.resource.data.quantity >= 1;\n    }\n\n    match /marketHistory/{historyId} {\n      allow read: if request.auth != null;\n      allow delete: if request.auth != null;\n      allow create: if request.auth != null\n        && request.resource.data.keys().hasOnly([\n          \"marketId\",\n          \"timestamp\",\n          \"price\",\n          \"volume\",\n          \"quantity\",\n          \"eventType\",\n          \"transactionId\"\n        ])\n        && request.resource.data.marketId is string\n        && request.resource.data.timestamp is number\n        && request.resource.data.price is number\n        && request.resource.data.price >= 1\n        && request.resource.data.volume is number\n        && request.resource.data.volume >= 0\n        && request.resource.data.quantity is number\n        && request.resource.data.quantity >= 0\n        && request.resource.data.eventType in [\n          \"create\",\n          \"drop_buy\",\n          \"bulk_drop_buy\",\n          \"buy\",\n          \"sell\",\n          \"bulk_buy\",\n          \"bulk_sell\",\n          \"price_update\",\n          \"resolve\"\n        ];\n    }\n\n    match /dropCycles/{cycleId} {\n      allow read: if request.auth != null;\n      allow create: if request.auth != null\n        && request.resource.data.keys().hasOnly([\n          \"dropTime\",\n          \"suggestionIds\",\n          \"createdBy\",\n          \"createdByName\",\n          \"createdAt\"\n        ])\n        && request.resource.data.dropTime is number\n        && request.resource.data.suggestionIds is list\n        && request.resource.data.suggestionIds.size() <= 3\n        && request.resource.data.createdBy == request.auth.uid\n        && request.resource.data.createdByName is string;\n    }\n\n    match /suggestions/{suggestionId} {\n      allow read: if request.auth != null;\n\r\n      allow create: if request.auth != null\r\n        && request.resource.data.keys().hasOnly([\r\n          \"name\",\n          \"category\",\n          \"reason\",\n          \"color\",\n          \"suggestedBy\",\n          \"suggestedByName\",\r\n          \"upvotes\",\r\n          \"voters\",\r\n          \"createdAt\",\r\n          \"updatedAt\"\r\n        ])\r\n        && request.resource.data.name is string\r\n        && request.resource.data.name.size() >= 2\r\n        && request.resource.data.name.size() <= 80\r\n        && request.resource.data.category in [\r\n          \"Event\",\r\n          \"Product\",\r\n          \"Music\",\n          \"Public Figure\",\n          \"Sports\",\n          \"Meme\",\n          \"Miscellaneous\"\n        ]\n        && request.resource.data.reason is string\n        && request.resource.data.reason.size() <= 300\n        && request.resource.data.color is string\n        && request.resource.data.suggestedBy == request.auth.uid\n        && request.resource.data.suggestedByName is string\r\n        && request.resource.data.suggestedByName.size() <= 80\r\n        && request.resource.data.upvotes == 1\r\n        && request.resource.data.voters is map\r\n        && request.resource.data.voters[request.auth.uid] == true;\r\n\r\n      allow update: if request.auth != null\r\n        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\r\n          \"upvotes\",\r\n          \"voters\",\r\n          \"updatedAt\"\r\n        ])\r\n        && resource.data.voters is map\r\n        && request.resource.data.voters is map\r\n        && !resource.data.voters.keys().hasAny([request.auth.uid])\r\n        && request.resource.data.voters[request.auth.uid] == true\r\n        && request.resource.data.upvotes == resource.data.upvotes + 1;\r\n\r\n      allow delete: if request.auth != null;\n    }\r\n  }\r\n}\r\n","name":"my-app/firestore.rules"}]},"createTime":"2026-05-02T14:11:17.722111Z","metadata":{"services":["cloud.firestore"]}}
