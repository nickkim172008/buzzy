rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "nutakkiabhiram@gmail.com";
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          "coins",
          "displayName",
          "email",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.coins is number
        && request.resource.data.coins >= 0;

      match /holdings/{marketId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;

        allow write: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.keys().hasOnly([
            "quantity",
            "averagePrice",
            "updatedAt"
          ])
          && request.resource.data.quantity is number
          && request.resource.data.quantity >= 0
          && request.resource.data.averagePrice is number
          && request.resource.data.averagePrice >= 0;
      }
    }

    match /markets/{marketId} {
      allow read: if request.auth != null;
      allow delete: if isAdmin();
      allow create: if request.auth != null
        && validMarketData()
        && (isAdmin()
          || (request.resource.data.source == "scheduled_drop"
            && marketId.matches("drop_.*")));
      allow update: if request.auth != null
        && validMarketData();

      function validMarketData() {
        return request.resource.data.keys().hasOnly([
            "name",
            "category",
            "level",
            "volatility",
            "lastPrice",
            "previousPrice",
            "volume",
            "supply",
            "description",
            "signal",
            "color",
            "totalSupply",
            "dropPrice",
            "soldDropSupply",
            "unsoldDropSupply",
            "activeTradableSupply",
            "remainingDropSupply",
            "status",
            "source",
            "createdBy",
            "createdByName",
            "createdAt",
            "updatedAt"
          ])
          && request.resource.data.name is string
          && request.resource.data.category is string
          && request.resource.data.level in ["admin", "community", "private"]
          && request.resource.data.lastPrice is number
          && request.resource.data.previousPrice is number
          && request.resource.data.volume is number
          && request.resource.data.totalSupply is number
          && request.resource.data.totalSupply >= 1
          && request.resource.data.dropPrice is number
          && request.resource.data.dropPrice >= 1
          && (!request.resource.data.keys().hasAny(["soldDropSupply"])
            || (request.resource.data.soldDropSupply is number
              && request.resource.data.soldDropSupply >= 0))
          && (!request.resource.data.keys().hasAny(["unsoldDropSupply"])
            || (request.resource.data.unsoldDropSupply is number
              && request.resource.data.unsoldDropSupply >= 0))
          && (!request.resource.data.keys().hasAny(["activeTradableSupply"])
            || (request.resource.data.activeTradableSupply is number
              && request.resource.data.activeTradableSupply >= 0))
          && request.resource.data.remainingDropSupply is number
          && request.resource.data.remainingDropSupply >= 0
          && request.resource.data.status in ["drop", "trading"]
          && (!request.resource.data.keys().hasAny(["source"])
            || request.resource.data.source in ["manual", "scheduled_drop"])
          && (!request.resource.data.keys().hasAny(["createdBy"])
            || request.resource.data.createdBy is string);
      }
    }

    match /balances/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly([
          "coins",
          "displayName",
          "email",
          "updatedAt"
        ])
        && request.resource.data.coins is number
        && request.resource.data.coins >= 0;
    }

    match /holdings/{holdingId} {
      allow read: if request.auth != null;
      allow delete: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly([
          "userId",
          "marketId",
          "quantity",
          "averagePrice",
          "updatedAt"
        ])
        && request.resource.data.userId is string
        && request.resource.data.marketId is string
        && request.resource.data.quantity is number
        && request.resource.data.quantity >= 0
        && request.resource.data.averagePrice is number
        && request.resource.data.averagePrice >= 0;
    }

    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow delete: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasOnly([
          "assetId",
          "userId",
          "user",
          "ownerCoins",
          "side",
          "limitPrice",
          "quantity",
          "remaining",
          "status",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.assetId is string
        && request.resource.data.userId is string
        && request.resource.data.user is string
        && (!request.resource.data.keys().hasAny(["ownerCoins"])
          || (request.resource.data.ownerCoins is number
            && request.resource.data.ownerCoins >= 0))
        && request.resource.data.side in ["buy", "sell"]
        && request.resource.data.limitPrice is number
        && request.resource.data.limitPrice >= 1
        && request.resource.data.quantity is number
        && request.resource.data.quantity >= 1
        && request.resource.data.remaining is number
        && request.resource.data.remaining >= 0
        && request.resource.data.status in ["open", "filled", "partially_filled"];
    }

    match /trades/{tradeId} {
      allow read: if request.auth != null;
      allow delete: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          "assetId",
          "buyerId",
          "buyer",
          "sellerId",
          "seller",
          "price",
          "quantity",
          "createdAt"
        ])
        && request.resource.data.assetId is string
        && request.resource.data.buyerId is string
        && request.resource.data.buyer is string
        && request.resource.data.sellerId is string
        && request.resource.data.seller is string
        && request.resource.data.price is number
        && request.resource.data.price >= 1
        && request.resource.data.quantity is number
        && request.resource.data.quantity >= 1;
    }

    match /marketHistory/{historyId} {
      allow read: if request.auth != null;
      allow delete: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          "marketId",
          "timestamp",
          "price",
          "volume",
          "quantity",
          "eventType",
          "transactionId"
        ])
        && request.resource.data.marketId is string
        && request.resource.data.timestamp is number
        && request.resource.data.price is number
        && request.resource.data.price >= 1
        && request.resource.data.volume is number
        && request.resource.data.volume >= 0
        && request.resource.data.quantity is number
        && request.resource.data.quantity >= 0
        && request.resource.data.eventType in [
          "create",
          "drop_buy",
          "bulk_drop_buy",
          "buy",
          "sell",
          "bulk_buy",
          "bulk_sell",
          "price_update",
          "resolve"
        ];
    }

    match /dropCycles/{cycleId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          "dropTime",
          "suggestionIds",
          "createdBy",
          "createdByName",
          "createdAt"
        ])
        && request.resource.data.dropTime is number
        && request.resource.data.suggestionIds is list
        && request.resource.data.suggestionIds.size() <= 3
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdByName is string;
    }

    match /suggestions/{suggestionId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          "name",
          "category",
          "reason",
          "color",
          "suggestedBy",
          "suggestedByName",
          "upvotes",
          "voters",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 80
        && request.resource.data.category in [
          "Event",
          "Product",
          "Music",
          "Public Figure",
          "Sports",
          "Meme",
          "Miscellaneous"
        ]
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 300
        && request.resource.data.color is string
        && request.resource.data.suggestedBy == request.auth.uid
        && request.resource.data.suggestedByName is string
        && request.resource.data.suggestedByName.size() <= 80
        && request.resource.data.upvotes == 1
        && request.resource.data.voters is map
        && request.resource.data.voters[request.auth.uid] == true;

      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "upvotes",
          "voters",
          "updatedAt"
        ])
        && resource.data.voters is map
        && request.resource.data.voters is map
        && !resource.data.voters.keys().hasAny([request.auth.uid])
        && request.resource.data.voters[request.auth.uid] == true
        && request.resource.data.upvotes == resource.data.upvotes + 1;

      allow delete: if request.auth != null;
    }
  }
}
